<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events - <%= selectedCategory %></title>
    <link rel="stylesheet" href="/css/events-list.css"> 
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>

    <div class="container">
        
        <header class="search-filter-section">
            <h1 class="page-title"><%= selectedCategory %> Events</h1>
            
            <form action="/events" method="GET" class="search-filter-form">
                
                <div class="search-bar-group">
                    <input type="text" name="query" placeholder="Search events in <%= selectedCategory %>..." value="<%= searchQuery %>">
                    <button type="submit" class="search-btn"><i class="fas fa-search"></i> Search</button>
                </div>
                
                <div class="filters-group">
                    <label for="category-filter">Category:</label>
                    <select id="category-filter" name="category" onchange="this.form.submit()">
                        <% allCategories.forEach(category => { %>
                            <option value="<%= category %>" <%= category === selectedCategory ? 'selected' : '' %>><%= category %></option>
                        <% }) %>
                    </select>
                </div>

                <a href="/events?category=<%= encodeURIComponent(selectedCategory) %>" class="clear-filters-btn">Clear Search</a>

            </form>
        </header>
        
        <hr>

        <main class="event-listings">
            <% if (events && events.length > 0) { %>
                <% events.forEach(event => { %>
                    <article class="event-card">
                        
                        <div class="event-image">
                            <img src="<%= event.imageUrl %>" alt="<%= event.name %>" loading="lazy">
                        </div>

                        <div class="event-details">
                            <h3 class="event-name"><a href="#"> <%= event.name %> </a></h3>
                            
                            <div class="event-content-flex">
                                
                                <div class="event-info-left">
                                    <p class="event-description">
                                        <%= event.description.substring(0, 150) %>...
                                    </p> 
                                    
                                    <div class="event-info">
                                        <p>
                                            <i class="fas fa-calendar-alt"></i> 
                                            <strong>Time:</strong> 
                                            <%= new Date(event.startTime).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' }) %>
                                        </p>
                                        <p>
                                            <i class="fas fa-map-marker-alt"></i> 
                                            <strong>Location:</strong> 
                                            <%= event.location %>
                                        </p>
                                        <p>
                                            <i class="fas fa-tag"></i> 
                                            <strong>Category:</strong> 
                                            <%= event.category %>
                                        </p>
                                    </div>
                                </div>

                                <div class="event-booking-right">
                                    <p class="event-rate">
                                        <i class="fas fa-money-bill-wave"></i> 
                                        Ticket Price: 
                                        <strong><%= event.rate %></strong>
                                    </p>
                                    
                                    <a href="/book/<%= event._id %>" class="btn-book-tickets">
                                        <i class="fas fa-ticket-alt"></i> Book Tickets
                                    </a>
                                </div>
                            </div>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="no-results">
                    <p>
                        <i class="fas fa-exclamation-circle"></i> 
                        No events found in <%= selectedCategory %> matching your search criteria.
                    </p>
                </div>
            <% } %>
        </main>

    </div>

</body>
</html>