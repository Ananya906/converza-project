<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login - Converza</title>
  <link rel="stylesheet" href="/css/login.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
</head>
<body>
  <div class="bg-gradient"></div>

  <div class="center-card">
    <div class="form-wrapper">
      <!-- Left column: event images -->
      <div class="left-images">
        <img src="/images/image1.jpg" alt="Event 1">
        <img src="/images/image2.jpeg" alt="Event 2">
        <img src="/images/images3.jpeg" alt="Event 3">
      </div>

      <!-- Right column: glass card login form -->
      <div class="glass-card">
        <h1 class="title">Converza Login</h1>
        <p class="subtitle">Sign in to manage your events</p>
        
        <% if (error) { %>
          <div id="login-error" class="error"><%= error %></div>
        <% } else { %>
          <div id="login-error" class="error"></div>
        <% } %>

        <!-- ✅ ID added, onsubmit REMOVED -->
        <form action="/login" method="POST" class="form" id="loginForm">
          
          <!-- Email -->
          <div class="input-field">
            <input 
              type="email" 
              id="email"
              name="email" 
              placeholder="Email" 
              required 
              class="input-style"
            />
            <i class="fa fa-envelope icon"></i>
          </div>

          <!-- Password -->
          <div class="input-field">
            <input 
              type="password" 
              name="password" 
              placeholder="Password" 
              required 
              class="input-style"
            />
            <i class="fa fa-lock icon"></i>
          </div>

          <!-- Role Selector -->
          <div class="input-field">
            <select name="role" required class="input-style">
              <option value="user">User</option>
              <option value="admin">Admin</option>
            </select>
            <i class="fa fa-user-shield icon"></i>
          </div>

          <div class="row-between">
            <label class="remember">
              <input type="checkbox" id="remember" name="remember" />
              Remember me
            </label>
            <a href="#" class="forgot">Forgot?</a>
          </div>

          <button class="btn" type="submit">Login</button>
        </form>

        <p class="bottom">
          Don't have an account? <a href="/register">Register</a>
        </p>
      </div>
    </div>
  </div>

  <!-- ✅ LocalStorage Remember Me Script -->
  <script>
    // Auto-fill email on page load
    window.addEventListener("DOMContentLoaded", function () {
        const savedEmail = localStorage.getItem("savedEmail");
        if (savedEmail) {
            document.getElementById("email").value = savedEmail;
            document.getElementById("remember").checked = true;
        }
    });

    // Save email before form submits
    document.getElementById("loginForm").addEventListener("submit", function () {
        const email = document.getElementById("email").value;
        const remember = document.getElementById("remember").checked;

        if (remember) {
            localStorage.setItem("savedEmail", email);
        } else {
            localStorage.removeItem("savedEmail");
        }
    });
  </script>
</body>
</html>
